WeatherServiceImpl.java

package ds;

import java.util.HashMap;

import javax.jws.WebService;

@WebService(endpointInterface = "ds.WeatherService")

public class WeatherServiceImpl
        implements WeatherService {

    HashMap<String, String> weatherMap =
            new HashMap<String, String>();

    // Add
    public String addCity(
            String city,
            String weather) {

        weatherMap.put(city, weather);

        return "City Weather Added";
    }

    // Update
    public String updateCity(
            String city,
            String weather) {

        if(weatherMap.containsKey(city)) {

            weatherMap.put(city, weather);

            return "Weather Updated";
        }

        return "City Not Found";
    }

    // Delete
    public String deleteCity(String city) {

        if(weatherMap.containsKey(city)) {

            weatherMap.remove(city);

            return "City Deleted";
        }

        return "City Not Found";
    }

    // View
    public String viewWeather() {

        String result = "";

        for(String city : weatherMap.keySet()) {

            result +=
                    "City: " + city +
                    " " +
                    weatherMap.get(city)
                    + "\n";
        }

        return result;
    }
}

WeatherService.java
package ds;

import javax.jws.WebMethod;
import javax.jws.WebService;

@WebService
public interface WeatherService {

    @WebMethod
    String addCity(String city, String weather);

    @WebMethod
    String updateCity(String city, String weather);

    @WebMethod
    String deleteCity(String city);

    @WebMethod
    String viewWeather();
}
