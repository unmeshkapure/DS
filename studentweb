package ds;

import javax.jws.WebMethod;
import javax.jws.WebService;

@WebService
public interface StudentService {

    @WebMethod
    String addStudent(int roll, String name);

    @WebMethod
    String updateStudent(int roll, String name);

    @WebMethod
    String deleteStudent(int roll);

    @WebMethod
    String viewStudents();
}




