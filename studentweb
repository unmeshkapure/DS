package ds;

import java.awt.*;
import java.awt.event.*;

import java.net.URL;

import javax.swing.*;

import javax.xml.namespace.QName;
import javax.xml.ws.Service;

public class StudentClient extends JFrame
        implements ActionListener {

    JTextField t1, t2;

    JTextArea area;

    JButton b1, b2, b3, b4;

    StudentService service;

    StudentClient() throws Exception {

        // Connect to Web Service
        URL url =
                new URL(
                        "http://localhost:8080/student?wsdl");

        QName qname =
                new QName(
                        "http://ds/",
                        "StudentServiceImplService");

        Service ws =
                Service.create(url, qname);

        service =
                ws.getPort(StudentService.class);

        // UI
        setTitle("Student Record System");

        setSize(400, 400);

        setLayout(new FlowLayout());

        add(new JLabel("Roll No"));

        t1 = new JTextField(20);

        add(t1);

        add(new JLabel("Name"));

        t2 = new JTextField(20);

        add(t2);

        b1 = new JButton("Add");

        b2 = new JButton("Update");

        b3 = new JButton("Delete");

        b4 = new JButton("View");

        add(b1);

        add(b2);

        add(b3);

        add(b4);

        area = new JTextArea(10, 30);

        add(area);

        b1.addActionListener(this);

        b2.addActionListener(this);

        b3.addActionListener(this);

        b4.addActionListener(this);

        setVisible(true);
    }

    public void actionPerformed(ActionEvent e) {

        int roll =
                Integer.parseInt(t1.getText());

        String name = t2.getText();

        // Add
        if(e.getSource() == b1) {

            area.setText(
                    service.addStudent(
                            roll, name));
        }

        // Update
        if(e.getSource() == b2) {

            area.setText(
                    service.updateStudent(
                            roll, name));
        }

        // Delete
        if(e.getSource() == b3) {

            area.setText(
                    service.deleteStudent(
                            roll));
        }

        // View
        if(e.getSource() == b4) {

            area.setText(
                    service.viewStudents());
        }
    }

    public static void main(String[] args)
            throws Exception {

        new StudentClient();
    }
}



