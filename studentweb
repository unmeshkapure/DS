StudentServiceImpl.java 
package ds;

import java.util.HashMap;
import javax.jws.WebService;

@WebService(endpointInterface = "ds.StudentService")

public class StudentServiceImpl implements StudentService {

    HashMap<Integer, String> students =
            new HashMap<Integer, String>();

    // Add
    public String addStudent(int roll, String name) {

        students.put(roll, name);

        return "Student Added";
    }

    // Update
    public String updateStudent(int roll, String name) {

        if(students.containsKey(roll)) {

            students.put(roll, name);

            return "Student Updated";
        }

        return "Student Not Found";
    }

    // Delete
    public String deleteStudent(int roll) {

        if(students.containsKey(roll)) {

            students.remove(roll);

            return "Student Deleted";
        }

        return "Student Not Found";
    }

    // View
    public String viewStudents() {

        String result = "";

        for(Integer roll : students.keySet()) {

            result +=
                    "Roll No: " + roll +
                    " Name: " + students.get(roll)
                    + "\n";
        }

        return result;
    }
}

